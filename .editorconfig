# .editorconfig
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = 100

[*.{json,json5,jsonc}]
indent_size = 2
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[*.{js,mjs,cjs,ts,mts,cts}]
indent_size = 2

[.gitignore]
trim_trailing_whitespace = false
