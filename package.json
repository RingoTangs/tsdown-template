{
  "name": "tsdown-template",
  "type": "module",
  "version": "0.1.3",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "description": "A TypeScript npm library template powered by tsdown.",
  "author": "RingoTangs",
  "license": "MIT",
  "homepage": "https://github.com/RingoTangs/tsdown-template#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RingoTangs/tsdown-template.git"
  },
  "bugs": {
    "url": "https://github.com/RingoTangs/tsdown-template/issues"
  },
  "keywords": [
    "typescript",
    "tsdown",
    "npm-package",
    "library",
    "template"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "build:publish": "cross-env BUILD_TARGET=publish tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -b",
    "pack:check": "npm pack --dry-run --ignore-scripts",
    "prepublishOnly": "pnpm release:check",
    "check": "pnpm lint && pnpm format && pnpm typecheck && pnpm test:run",
    "fix": "pnpm lint:fix && pnpm format:fix",
    "release:check": "pnpm check && pnpm build:publish && pnpm pack:check",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@antfu/eslint-config": "6.2.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/node": "^22.19.17",
    "cross-env": "^10.1.0",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
